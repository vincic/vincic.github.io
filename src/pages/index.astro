---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { sortedPosts } from '@/lib/posts';
const posts = sortedPosts(await getCollection('posts')).slice(0, 3);
---
<SiteLayout title="Sasha Vinčić" description="AI engineering, software leadership, workshops, writing, and practical technical work by Sasha Vinčić.">
  <section class="mx-auto max-w-6xl px-5 py-20 md:py-28">
    <p class="mb-6 text-sm uppercase tracking-[0.25em] text-base-500">AI engineering · software leadership · workshops</p>
    <h1 class="max-w-5xl font-serif text-6xl font-light leading-[0.95] tracking-tight text-base-950 md:text-8xl">I help teams turn AI from a demo into working software.</h1>
    <p class="mt-8 max-w-2xl text-xl leading-8 text-base-650">I am Sasha Vinčić, a software engineer and technical leader in Malmö. I work with AI-assisted engineering, product teams, workshops, and the boring systems work that makes ambitious ideas survive contact with reality.</p>
    <div class="mt-10 flex flex-wrap gap-3">
      <a href="/work/" class="rounded-full bg-base-950 px-5 py-3 text-sm font-medium text-white hover:bg-base-800">Work with me</a>
      <a href="/blog/" class="rounded-full border border-base-300 px-5 py-3 text-sm font-medium text-base-900 hover:border-base-950">Read writing</a>
    </div>
  </section>
  <section class="mx-auto max-w-6xl px-5 py-12 border-t border-base-200">
    <div class="grid gap-8 md:grid-cols-3">
      <div><h2 class="font-serif text-3xl font-light">AI, used properly</h2><p class="mt-3 leading-7 text-base-600">Workshops and hands-on engineering for teams that need more than prompt tricks.</p></div>
      <div><h2 class="font-serif text-3xl font-light">Technical leadership</h2><p class="mt-3 leading-7 text-base-600">25+ years of software engineering, product judgement, code archaeology, and team enablement.</p></div>
      <div><h2 class="font-serif text-3xl font-light">Useful writing</h2><p class="mt-3 leading-7 text-base-600">Notes on AI, engineering practice, leadership, tools, and the occasional personal detour.</p></div>
    </div>
  </section>
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="mb-8 flex items-end justify-between gap-6">
      <h2 class="font-serif text-5xl font-light tracking-tight">Latest writing</h2>
      <a class="text-sm text-base-600 hover:text-base-950" href="/blog/">All posts →</a>
    </div>
    {posts.map((post, index) => <BlogCard post={post} large={index === 0} />)}
  </section>
</SiteLayout>
