---
import SiteLayout from '@/layouts/SiteLayout.astro';
---
<SiteLayout title="Contact" description="Contact Sasha Vinčić.">
  <section class="mx-auto max-w-3xl px-5 py-20 md:py-28">
    <p class="mb-5 text-sm uppercase tracking-[0.25em] text-base-500">Contact</p>
    <h1 class="font-serif text-6xl font-light tracking-tight md:text-7xl">Talk to me.</h1>
    <div class="prose prose-lg mt-10 max-w-none">
      <p>Email is best: <a href="mailto:sasha@vincic.org">sasha@vincic.org</a>.</p>
      <p>You can also find me on <a href="https://se.linkedin.com/in/sashav/sv">LinkedIn</a> and <a href="https://github.com/vincic">GitHub</a>.</p>
    </div>
  </section>
</SiteLayout>
