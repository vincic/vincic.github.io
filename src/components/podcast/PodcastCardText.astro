---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
const { url, title, pubDate } = {
  url: "/podcast/interviews/" + Astro.props.post.id,
  title: Astro.props.post.data.title,
  pubDate: new Date(Astro.props.post.data.pubDate).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "2-digit",
  }),
};
---

<article>
  <Text tag="p" variant="textXS" class="uppercase text-base-400">
    <time datetime={pubDate}>{pubDate}</time>
  </Text>
  <Text
    href={url}
    title={title}
    aria-label={`Listen to: ${title}`}
    tag="a"
    variant="textSM"
    class="font-medium text-base-900 hover:text-base-600 text-balance"
  >
    {title}
  </Text>
</article>
