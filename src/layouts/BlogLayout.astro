---
// Assets
import { Image } from "astro:assets";
import ShareButtons from "@/components/fundations/elements/ShareButtons.astro";
// Fundations
import BaseLayout from "./BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Sections
import Subscribe from "@/components/ctas/Subscribe.astro";
import BlogCard2 from "@/components/blog/BlogCard2.astro";
// Props
const { frontmatter, previous, next, slug } = Astro.props;
import { getEntry } from "astro:content";
const author = await getEntry("authors", frontmatter.author);
// Get all posts and filter by tag
import { getCollection } from "astro:content";
const allPosts = await getCollection("posts");
const currentSlug =
  slug ||
  frontmatter.slug ||
  (Astro.url?.pathname
    ? Astro.url.pathname.split("/").filter(Boolean).pop()
    : "");
const relatedPosts = allPosts.filter(
  (post) =>
    post.id !== currentSlug &&
    Array.isArray(post.data.tags) &&
    Array.isArray(frontmatter.tags) &&
    post.data.tags.some((tag) => frontmatter.tags.includes(tag))
);
---

<BaseLayout>
  <section>
    <Wrapper variant="standard">
      <div class="relative">
        <!-- Sticky Text -->
        <div class="sticky top-0 z-10 pt-32">
          <Text
            tag="h1"
            variant="display3XL"
            class="max-w-4xl mx-auto font-serif font-light tracking-tight text-center text-base-900 mix-blend-difference text-balance"
          >
            {frontmatter.title}
          </Text>
        </div>
        <div class="relative z-10">
          <!-- Background Image -->
          <Image
            width={1000}
            height={1000}
            src={frontmatter.image.url}
            alt={frontmatter.image.alt}
            class="object-cover w-full h-auto max-w-xl mx-auto mt-24"
          />
        </div>
      </div>
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="narrow" class="pt-24">
      <div>
        <div>
          {
            author && (
              <a
                href={`/authors/${author.id}`}
                class="flex items-center justify-center gap-3 hover:opacity-80 transition"
              >
                {author?.data?.image?.url && (
                  <Image
                    width={100}
                    height={100}
                    src={author.data.image.url}
                    alt={author.data.image.alt}
                    class="inline-block object-cover object-center rounded-full size-10"
                  />
                )}
                <Text tag="p" variant="textXS" class="text-base-600 ">
                  <span class="">
                    Written in
                    <span class="italic font-medium text-base-600">
                      <time
                        datetime={new Date(frontmatter.pubDate).toISOString()}
                      >
                        {new Date(frontmatter.pubDate).toLocaleDateString(
                          "en-US",
                          {
                            year: "numeric",
                            month: "long",
                            day: "2-digit",
                          }
                        )}
                      </time>
                    </span>
                  </span>
                  <span class="">
                    by
                    <span class="italic font-medium text-base-600">
                      {author.data.name}
                    </span>
                  </span>
                  <span class="block"> {author.data.role}</span>
                </Text>
              </a>
            )
          }
          <Text
            tag="h1"
            variant="displayMD"
            class="mt-8 font-serif font-light text-center leading-6 md:leading-8 text-base-600 text-balance"
          >
            {frontmatter.description}
          </Text>
          <div class="flex justify-center mt-4 gap-2">
            {
              frontmatter.tags.map((tag) => (
                <span>
                  <a
                    href={`/tags/${tag}`}
                    class="text-xs font-medium uppercase text-base-600 hover:underline"
                  >
                    {tag}
                  </a>
                </span>
              ))
            }
          </div>
        </div>
        {
          frontmatter.isLocked ? (
            <div class="py-20 text-center">
              <Text
                tag="h4"
                variant="displaySM"
                class="max-w-4xl mx-auto font-serif font-light tracking-tight text-center text-base-900  text-balance"
              >
                This post is for subscribers only. Unlock premium insights by
                becoming a member.
              </Text>
              <div class="flex flex-wrap justify-center mt-8 gap-2">
                <Button isLink size="sm" variant="muted" href="/login">
                  Log in
                </Button>
                <Button isLink size="sm" variant="default" href="/pricing">
                  Subscribe Now
                </Button>
              </div>
            </div>
          ) : (
            <>
              <Wrapper variant="prose" class="max-w-xl mx-auto mt-24">
                <slot />
              </Wrapper>
              <div class="pt-6 mt-6 border-t border-black">
                <ShareButtons
                  contentType="blog"
                  description={frontmatter.description}
                />
              </div>
            </>
          )
        }
      </div>
    </Wrapper>
    <Wrapper variant="standard" class="pb-24 pt-8">
      <nav
        class="flex flex-col md:flex-row lg:justify-between gap-4 lg:items-center relative text-xs"
      >
        {
          previous && (
            <a href={`/blog/posts/${previous.id}`} class="hover:opacity-80 ">
              <span class="block  text-base-900 font-medium uppercase">
                Previous:
              </span>
              <span class="block  text-base-600"> {previous.data.title}</span>
            </a>
          )
        }
        {
          next && (
            <a
              href={`/blog/posts/${next.id}`}
              class=" hover:opacity-80 text-right"
            >
              <span class="block  text-base-900 font-medium uppercase ">
                Next:
              </span>
              <span class="block  text-base-600"> {next.data.title}</span>
            </a>
          )
        }
      </nav>
    </Wrapper>
  </section>
  {
    relatedPosts.length > 0 && (
      <section>
        <Wrapper variant="standard" class="py-8">
          <Text
            tag="h2"
            variant="displayMD"
            class="font-serif font-light text-base-600"
          >
            Related posts
          </Text>
          <div class="items-start pt-2 mt-2 border-t border-black grid grid-cols-1 sm:grid-cols-2 md:grid-cols-2 gap-2">
            {relatedPosts.slice(0, 3).map((post) => (
              <BlogCard2 post={post} />
            ))}
          </div>
        </Wrapper>
      </section>
    )
  }
  <Subscribe />
</BaseLayout>
