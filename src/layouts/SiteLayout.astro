---
import '../styles/global.css';
const {
  title = 'Sasha Vinčić',
  description = 'AI engineering, software leadership, workshops, writing, and practical technical work by Sasha Vinčić.',
} = Astro.props;
const fullTitle = title === 'Sasha Vinčić' ? title : `${title} — Sasha Vinčić`;
---
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" type="application/rss+xml" title="Sasha Vinčić" href="/rss.xml" />
  </head>
  <body class="min-h-screen bg-base-50 text-base-950 antialiased selection:bg-base-950 selection:text-base-50">
    <header class="border-b border-base-200 bg-base-50/90 backdrop-blur sticky top-0 z-50">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 text-sm">
        <a href="/" class="font-serif text-xl tracking-tight hover:opacity-70">Sasha Vinčić</a>
        <div class="flex items-center gap-5 text-base-700">
          <a class="hover:text-base-950" href="/about/">About</a>
          <a class="hover:text-base-950" href="/work/">Work</a>
          <a class="hover:text-base-950" href="/blog/">Writing</a>
          <a class="hover:text-base-950" href="/contact/">Contact</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-base-200 mt-24">
      <div class="mx-auto max-w-6xl px-5 py-10 text-sm text-base-600 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <p>© {new Date().getFullYear()} Sasha Vinčić</p>
        <p><a class="hover:text-base-950" href="https://github.com/vincic">GitHub</a> · <a class="hover:text-base-950" href="https://se.linkedin.com/in/sashav/sv">LinkedIn</a> · <a class="hover:text-base-950" href="mailto:sasha@vincic.org">Email</a></p>
      </div>
    </footer>
  </body>
</html>
