---
import { getCollection } from 'astro:content';
import SiteLayout from '@/layouts/SiteLayout.astro';
import BlogTextRow from '@/components/blog/BlogTextRow.astro';
import BlogSectionCard from '@/components/blog/BlogSectionCard.astro';
import { postsByIds, sortedPosts } from '@/lib/posts';
const allPosts = await getCollection('posts');
const posts = sortedPosts(allPosts);
const postsByYear = posts.reduce((groups, post) => {
  const year = String((post.data.pubDate ?? post.data.date ?? new Date('1970-01-01')).getFullYear());
  if (!groups.has(year)) groups.set(year, []);
  groups.get(year)?.push(post);
  return groups;
}, new Map());
const sections = [
  { title: 'Agentic engineering', description: 'AI, agents, coding workflows, and practical adoption.', ids: ['2024/07/16/exploring-selfhosted-ai-augmented-coding', '2024/07/beyond-copilot-ai-augmented-coding', '2024/07/ai-assistant-team-amplifier'] },
  { title: 'Software craft', description: 'Code archaeology, Git habits, security, and the work around the code.', ids: ['2024/07/mastering-git-blame', '2024/06/mastering-git-commit-message', '2024/09/piping-curl-to-bash-convenient-but-risky'] },
  { title: 'Founder notes', description: 'Building companies, teams, products, and judgement.', ids: ['2024/06/from-advisor-to-full-time', '2025/01/progress-and-protocol', '2016/05/time-for-change'] },
  { title: 'Personal field notes', description: 'Energy, learning, family projects, and occasional detours.', ids: ['2025/07/chasing-energy-fuels-passion', '2025/05/boombox-bonding', '2024/08/power-of-focus'] },
].map((section) => ({ ...section, posts: postsByIds(allPosts, section.ids) })).filter((section) => section.posts.length > 0);
---
<SiteLayout title="Blog" description="Notes by Sasha Vinčić on agentic engineering, software work, founders, and the occasional personal detour.">
  <section class="mx-auto max-w-6xl px-5 py-20">
    <p class="mb-5 text-sm uppercase tracking-[0.25em] text-base-500">Blog</p>
    <h1 class="max-w-4xl font-serif text-6xl font-light leading-tight tracking-tight md:text-7xl">Notes on agentic engineering, software work, founders, and the occasional personal detour.</h1>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-12">
    <div class="space-y-14">
      {sections.map((section) => <section class="border-t border-base-300 pt-8">
        <div class="mb-6 max-w-3xl">
          <h2 class="font-serif text-4xl font-light tracking-tight">{section.title}</h2>
          <p class="mt-3 leading-7 text-base-600">{section.description}</p>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
          {section.posts.map((post) => <BlogSectionCard post={post} />)}
        </div>
      </section>)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16 border-t border-base-200">
    <h2 class="font-serif text-5xl font-light tracking-tight">All posts</h2>
    <div class="mt-10 space-y-12">
      {[...postsByYear.entries()].map(([year, yearPosts]) => <section class="grid gap-4 md:grid-cols-[8rem_1fr]">
        <h3 class="font-serif text-3xl font-light tracking-tight text-base-950">{year}</h3>
        <div>
          {yearPosts.map((post) => <BlogTextRow post={post} />)}
        </div>
      </section>)}
    </div>
  </section>
</SiteLayout>
